    "dependencies": {
        "axios": "^1.7.0",
        "dotenv": "^16.4.0",
        "ethers": "^6.13.0",
        "express": "^4.21.0",
        "pino": "^10.3.1",
        "viem": "^2.47.0",
        "x402-axios": "^1.1.0",
        "yargs": "^17.7.2",
