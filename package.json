    "description": "OpenClaw + Agent DNS Settlement Integration with ELSA X402 Micropayment Protocol (heyelsa.ai)",
    "main": "agent-dns-openclaw-integration.js",
    "scripts": {
        "start": "node agent-dns-openclaw-integration-fixed.js",
        "buyer": "node agent-dns-openclaw-integration-fixed.js --agent-type buyer --port 8080",
        "seller": "node agent-dns-openclaw-integration-fixed.js --agent-type seller --port 8081",
        "dev": "node agent-dns-openclaw-integration-fixed.js --agent-type buyer --port 8080",
        "test": "node test-openclaw.js",
        "test:integration": "node test/integration.test.js",
        "cli": "node cli.js"
    },
    "keywords": [
        "openclaw",
