# ============================================================
# OpenClaw + Agent DNS Settlement Configuration
# Reference: https://github.com/HeyElsa/elsa-openclaw
# ============================================================

# ─── Required ──────────────────────────────────────────────
# Private key for x402 API micropayments (USDC on Base)
# Fund this wallet with USDC at https://x402.heyelsa.ai/
PAYMENT_PRIVATE_KEY=0x_YOUR_PAYMENT_PRIVATE_KEY_HERE

# ─── Optional ─────────────────────────────────────────────
# Separate key for signing swap transactions
# Falls back to PAYMENT_PRIVATE_KEY if not set
# Recommended: Use different wallets for payments vs. trading
TRADE_PRIVATE_KEY=

# Wallet address (auto-derived from private key if not set)
WALLET_ADDRESS=

# ─── Agent Configuration ──────────────────────────────────
AGENT_TYPE=buyer
CHAIN=base
PORT=8080

# Execution mode: 'dry_run' (safe, simulation only) or 'confirmed' (real transactions)
EXECUTION_MODE=dry_run

# ─── ELSA API ─────────────────────────────────────────────
ELSA_API_URL=https://x402-api.heyelsa.ai

# Enable execution tools (swaps, limit orders, perps)
# WARNING: When true, tools perform REAL onchain transactions!
ELSA_ENABLE_EXECUTION_TOOLS=false

# ─── Budget Controls ──────────────────────────────────────
# Per-call max (USD)
ELSA_MAX_USD_PER_CALL=0.05

# Daily budget (USD)
ELSA_MAX_USD_PER_DAY=2.00

# Rate limit (calls per minute)
ELSA_MAX_CALLS_PER_MINUTE=30

# Timezone for daily budget reset
ELSA_TZ=UTC

# ─── Security ─────────────────────────────────────────────
# Require confirmation token from dry-run before execution
ELSA_REQUIRE_CONFIRMATION_TOKEN=true

# Confirmation token TTL (seconds)
ELSA_CONFIRMATION_TTL_SECONDS=300

# Audit log path (optional)
ELSA_AUDIT_LOG_PATH=

# ─── Blockchain RPC ───────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
